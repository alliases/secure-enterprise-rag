# Required API Keys [cite: 61]
OPENAI_API_KEY=your_openai_api_key_here

# Infrastructure Configuration [cite: 61]
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=rag_db
POSTGRES_DSN=postgresql+asyncpg://postgres:postgres@postgres:5432/rag_db

REDIS_URL=redis://redis:6379/0

QDRANT_HOST=qdrant
QDRANT_PORT=6333

# Authentication [cite: 61]
JWT_SECRET=your_super_secret_jwt_key
JWT_ALGORITHM=HS256

# Model Configuration [cite: 61]
EMBEDDING_MODEL=text-embedding-3-small
LLM_MODEL=gpt-4o

# Application Settings
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
LOG_LEVEL=INFO
