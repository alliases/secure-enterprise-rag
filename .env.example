# Required API Keys
OPENAI_API_KEY=your_openai_api_key_here

# Infrastructure Configuration (Defaults set for local host execution)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=rag_db
# Docker Compose will automatically override 'localhost' to 'postgres' internally
POSTGRES_DSN=postgresql+asyncpg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@localhost:5432/${POSTGRES_DB}

# Defaults set for local host execution. Docker Compose overrides these internally.
REDIS_URL=redis://localhost:6379/0
QDRANT_HOST=localhost
QDRANT_PORT=6333

# Authentication
# CRITICAL: In production, generate a secure key using: openssl rand -hex 32
JWT_SECRET=your_super_secret_jwt_key_please_change_in_production
JWT_ALGORITHM=HS256

# Model Configuration
EMBEDDING_MODEL=text-embedding-3-small
LLM_MODEL=gpt-4o

# Application Settings
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
LOG_LEVEL=INFO
